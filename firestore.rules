rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Document ID: userId (UID from Auth)
    // Fields:
    //   - fullName: string (required)
    //   - mobileNumber: string (required)
    //   - role: string (required, 'admin' or 'user')
    //   - photoURL: string (optional)
    //   - createdAt: string (required)
    //
    // Collection: admin_keys
    // Document ID: key string
    // Fields:
    //   - key: string (required)
    //   - used: bool (required)
    //   - createdBy: string (optional)
    //   - createdAt: string (required)
    //
    // Collection: assignments
    // Document ID: auto-generated
    // Fields:
    //   - borrowerName: string (required)
    //   - mobileNumber: string (required)
    //   - ciOfficerId: string (required)
    //   - status: string (required)
    //   - timeline: list (required)
    //   ... other fields
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isSignedIn() {
      return request.auth != null;
    }

    function isEmailAdmin() {
      return isSignedIn() && 
             'email' in request.auth.token && 
             request.auth.token.email == "1stmb.mj@gmail.com";
    }

    function isDBAdmin() {
      return isSignedIn() && 
             exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
             'role' in get(/databases/$(database)/documents/users/$(request.auth.uid)).data &&
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "admin";
    }

    function isAdmin() {
      return isEmailAdmin() || isDBAdmin();
    }

    function isCoordinator() {
      return isSignedIn() && 
             exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
             'role' in get(/databases/$(database)/documents/users/$(request.auth.uid)).data &&
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "coordinator";
    }

    function isSupervisor() {
      return isSignedIn() && 
             exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
             'role' in get(/databases/$(database)/documents/users/$(request.auth.uid)).data &&
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "supervisor";
    }

    function isPrivileged() {
      return isAdmin() || isCoordinator() || isSupervisor();
    }

    function isVerified() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() > 0 && id.size() <= 128;
    }

    function isValidAssignment(data) {
      return data.keys().hasAll(['borrowerName', 'mobileNumber', 'ciOfficerId', 'status', 'timeline']) &&
             data.borrowerName is string &&
             data.status is string &&
             data.timeline is list;
    }

    function isValidNotification(data) {
      return data.keys().hasAll(['userId', 'title', 'message', 'type', 'read', 'createdAt']) &&
             data.userId is string &&
             data.title is string && data.title.size() < 200 &&
             data.message is string && data.message.size() < 1000 &&
             data.type in ['info', 'assignment', 'status_change'] &&
             data.read is bool &&
             data.createdAt is string;
    }

    function isValidAttendance(data) {
      let requiredFields = ['userId', 'userName', 'date', 'status', 'createdAt'];
      return data.keys().hasAll(requiredFields) &&
             data.userId is string &&
             data.userName is string &&
             data.date is string &&
             data.status in ["ON TIME", "LATE", "UNDERTIME", "OVERTIME"] &&
             data.createdAt is string;
    }

    function isValidLeaveRequest(data) {
      let requiredFields = ['userId', 'userName', 'leaveType', 'startDate', 'endDate', 'reason', 'status', 'createdAt'];
      return data.keys().hasAll(requiredFields) &&
             data.userId is string &&
             data.userName is string &&
             data.leaveType is string &&
             data.startDate is string &&
             data.endDate is string &&
             data.reason is string &&
             data.status in ['Pending', 'Approved', 'Rejected'] &&
             data.createdAt is string;
    }

    function isValidOvertimeRequest(data) {
      let requiredFields = ['userId', 'userName', 'date', 'hours', 'minutes', 'reason', 'status', 'createdAt'];
      return data.keys().hasAll(requiredFields) &&
             data.userId is string &&
             data.userName is string &&
             data.date is string &&
             data.hours is number &&
             data.minutes is number &&
             data.reason is string &&
             data.status in ['Pending', 'Approved', 'Rejected'] &&
             data.createdAt is string;
    }

    function isValidOBRequest(data) {
      let requiredFields = ['userId', 'userName', 'startDate', 'endDate', 'reason', 'status', 'createdAt'];
      return data.keys().hasAll(requiredFields) &&
             data.userId is string &&
             data.userName is string &&
             data.startDate is string &&
             data.endDate is string &&
             data.reason is string &&
             data.status in ['Pending', 'Approved', 'Rejected'] &&
             data.createdAt is string;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /attendance/{attendanceId} {
      allow list: if isSignedIn() && (resource.data.userId == request.auth.uid || isPrivileged());
      allow get: if isSignedIn() && (resource.data.userId == request.auth.uid || isPrivileged());
      allow create: if isSignedIn() && isValidAttendance(request.resource.data) && (request.resource.data.userId == request.auth.uid || isPrivileged());
      allow update: if isSignedIn() && (isPrivileged() || resource.data.userId == request.auth.uid) && isValidAttendance(request.resource.data);
      allow delete: if isAdmin();
    }

    match /leaves/{leaveId} {
      allow list: if isSignedIn() && (resource.data.userId == request.auth.uid || isPrivileged());
      allow get: if isSignedIn() && (resource.data.userId == request.auth.uid || isPrivileged());
      allow create: if isSignedIn() && isValidLeaveRequest(request.resource.data) && (request.resource.data.userId == request.auth.uid || isPrivileged());
      allow update: if isSignedIn() && (isPrivileged() || resource.data.userId == request.auth.uid) && isValidLeaveRequest(request.resource.data);
      allow delete: if isAdmin();
    }

    match /overtime/{overtimeId} {
      allow list: if isSignedIn() && (resource.data.userId == request.auth.uid || isPrivileged());
      allow get: if isSignedIn() && (resource.data.userId == request.auth.uid || isPrivileged());
      allow create: if isSignedIn() && isValidOvertimeRequest(request.resource.data) && (request.resource.data.userId == request.auth.uid || isPrivileged());
      allow update: if isSignedIn() && (isPrivileged() || resource.data.userId == request.auth.uid) && isValidOvertimeRequest(request.resource.data);
      allow delete: if isAdmin();
    }

    match /ob_requests/{obId} {
      allow list: if isSignedIn() && (resource.data.userId == request.auth.uid || isPrivileged());
      allow get: if isSignedIn() && (resource.data.userId == request.auth.uid || isPrivileged());
      allow create: if isSignedIn() && isValidOBRequest(request.resource.data) && (request.resource.data.userId == request.auth.uid || isPrivileged());
      allow update: if isSignedIn() && (isPrivileged() || resource.data.userId == request.auth.uid) && isValidOBRequest(request.resource.data);
      allow delete: if isAdmin();
    }

    match /notifications/{notificationId} {
      // Use resource.data check for list since it's the recipient
      allow list: if isSignedIn() && (resource.data.userId == request.auth.uid || isPrivileged());
      allow get: if isSignedIn() && (resource.data.userId == request.auth.uid || isPrivileged());
      allow create: if isSignedIn() && isValidNotification(request.resource.data);
      allow update: if isSignedIn() && isOwner(resource.data.userId) && 
                    request.resource.data.diff(resource.data).affectedKeys().hasOnly(['read']);
      allow delete: if (isOwner(resource.data.userId) || isPrivileged()) && isSignedIn();
    }

    match /scoringConfigs/{configId} {
      allow read: if isSignedIn();
      allow write: if isPrivileged();
    }

    match /users/{userId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && (isOwner(userId) || isAdmin());
      allow update: if isSignedIn() && (isOwner(userId) || isAdmin()) &&
                    (isAdmin() || request.resource.data.get('role', 'user') == resource.data.get('role', 'user'));
      allow delete: if isAdmin();
    }

    match /admin_keys/{keyId} {
      allow read: if isSignedIn();
      allow create: if isAdmin();
      allow update: if isSignedIn() && (
        isAdmin() || (
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['used', 'usedBy', 'usedAt']) && 
          request.resource.data.used == true
        )
      );
      allow delete: if isAdmin();
    }

    match /assignments/{assignmentId} {
      // Regular users only see their own assigned accounts. Privileged roles see all.
      allow list: if isSignedIn() && (isPrivileged() || resource.data.ciOfficerId == request.auth.uid);
      allow get: if isSignedIn() && (isPrivileged() || resource.data.ciOfficerId == request.auth.uid);
      allow create: if isPrivileged() && isValidAssignment(request.resource.data);
      allow update: if isSignedIn() && isValidAssignment(request.resource.data) &&
                    (isPrivileged() || request.auth.uid == resource.data.ciOfficerId);
      allow delete: if isAdmin();
    }

    match /evaluations/{evaluationId} {
      allow list: if isSignedIn() && (isPrivileged() || resource.data.employeeId == request.auth.uid);
      allow get: if isSignedIn() && (isPrivileged() || resource.data.employeeId == request.auth.uid);
      allow create: if isSignedIn() && (isPrivileged() || request.resource.data.employeeId == request.auth.uid);
      allow update: if isSignedIn() && isPrivileged();
      allow delete: if isAdmin();
    }
  }
}
