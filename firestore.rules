rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Document ID: userId
    // Fields:
    //   - fullName: string (required)
    //   - mobileNumber: string (required)
    //   - role: string (required, 'admin' | 'user')
    //   - photoURL: string (optional)
    //   - createdAt: timestamp (required)
    //
    // Collection: adminKeys
    // Document ID: keyId
    // Fields:
    //   - key: string (required, 4 digits)
    //   - used: bool (required)
    //   - createdBy: string (required)
    //   - createdAt: timestamp (required)
    //
    // Collection: assignments
    // Document ID: assignmentId
    // Fields:
    //   - borrowerName: string (required)
    //   - mobileNumber: string (required)
    //   - ciOfficerId: string (required)
    //   - status: string (required)
    //   - timeline: list (required)
    //   ... other loan fields
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
          (request.auth.token.email == "1stmb.mj@gmail.com" && request.auth.token.email_verified == true));
    }

    function isSuperAdmin() {
      return isAuthenticated() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.mobileNumber == '09327481042';
    }

    function isValidUser(data) {
      return data.keys().hasAll(['fullName', 'mobileNumber', 'role', 'createdAt']) &&
             data.fullName is string && data.fullName.size() > 0 &&
             data.mobileNumber is string && data.mobileNumber.size() >= 10 &&
             data.role in ['admin', 'user', 'coordinator'];
    }

    function isValidAssignment(data) {
      return data.keys().hasAll(['borrowerName', 'mobileNumber', 'ciOfficerId', 'status', 'timeline']) &&
             data.borrowerName is string && data.borrowerName.size() > 0 &&
             data.mobileNumber is string && data.ciOfficerId is string &&
             data.status is string && data.timeline is list;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isValidUser(request.resource.data) && 
                    (request.resource.data.role == 'user' || isSuperAdmin() || exists(/databases/$(database)/documents/adminKeys/$(request.resource.data.adminKey)));
      allow update: if isAuthenticated() && (isOwner(userId) || isAdmin()) && isValidUser(request.resource.data);
    }

    match /adminKeys/{keyId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    match /assignments/{assignmentId} {
      allow read: if isAuthenticated() && (isAdmin() || resource.data.ciOfficerId == request.auth.uid);
      allow create: if isAdmin();
      allow update: if isAuthenticated() && (isAdmin() || resource.data.ciOfficerId == request.auth.uid) && isValidAssignment(request.resource.data);
      allow delete: if isAdmin();
    }
  }
}
