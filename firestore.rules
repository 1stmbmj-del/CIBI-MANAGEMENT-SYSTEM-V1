rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Document ID: userId (UID from Auth)
    // Fields:
    //   - fullName: string (required)
    //   - mobileNumber: string (required)
    //   - role: string (required, 'admin' or 'user')
    //   - photoURL: string (optional)
    //   - createdAt: string (required)
    //
    // Collection: admin_keys
    // Document ID: key string
    // Fields:
    //   - key: string (required)
    //   - used: bool (required)
    //   - createdBy: string (optional)
    //   - createdAt: string (required)
    //
    // Collection: assignments
    // Document ID: auto-generated
    // Fields:
    //   - borrowerName: string (required)
    //   - mobileNumber: string (required)
    //   - ciOfficerId: string (required)
    //   - status: string (required)
    //   - timeline: list (required)
    //   ... other fields
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isSignedIn() {
      return request.auth != null;
    }

    function isEmailAdmin() {
      return isSignedIn() && request.auth.token.email == "1stmb.mj@gmail.com";
    }

    function isDBAdmin() {
      return isSignedIn() && 
             exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "admin";
    }

    function isAdmin() {
      return isEmailAdmin() || isDBAdmin();
    }

    function isVerified() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() > 0 && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function isValidAssignment(data) {
      return data.keys().hasAll(['borrowerName', 'mobileNumber', 'accountType', 'location', 'tribe', 'requestedAmount', 'term', 'intRate', 'mop', 'top', 'ciOfficerId', 'ciOfficerName', 'status', 'timeline', 'createdAt']) &&
             data.borrowerName is string && data.borrowerName.size() > 0 && data.borrowerName.size() <= 500 &&
             data.mobileNumber is string && data.mobileNumber.size() <= 100 &&
             data.accountType is string &&
             data.location is string &&
             data.tribe is string &&
             data.requestedAmount is number &&
             data.term is string &&
             data.intRate is number &&
             data.mop is string &&
             data.top is string &&
             data.ciOfficerId is string &&
             data.ciOfficerName is string &&
             data.status is string &&
             data.timeline is list &&
             data.createdAt is string;
    }

    function isValidNotification(data) {
      return data.keys().hasAll(['userId', 'title', 'message', 'type', 'read', 'createdAt']) &&
             data.userId is string &&
             data.title is string && data.title.size() < 200 &&
             data.message is string && data.message.size() < 1000 &&
             data.type in ['info', 'assignment', 'status_change'] &&
             data.read is bool &&
             data.createdAt is string;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /notifications/{notificationId} {
      // Use resource.data check for list since it's the recipient
      allow list: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow get: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isSignedIn() && isValidNotification(request.resource.data);
      allow update: if isSignedIn() && isOwner(resource.data.userId) && 
                    request.resource.data.diff(resource.data).affectedKeys().hasOnly(['read']);
      allow delete: if (isOwner(resource.data.userId) || isAdmin()) && isSignedIn();
    }

    match /scoringConfigs/{configId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /users/{userId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && (isOwner(userId) || isAdmin());
      allow update: if isSignedIn() && (isOwner(userId) || isAdmin()) &&
                    (isAdmin() || request.resource.data.get('role', 'user') == resource.data.get('role', 'user'));
      allow delete: if isAdmin();
    }

    match /admin_keys/{keyId} {
      allow read: if isSignedIn();
      allow create: if isAdmin();
      allow update: if isSignedIn() && (
        isAdmin() || (
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['used', 'usedBy', 'usedAt']) && 
          request.resource.data.used == true
        )
      );
      allow delete: if isAdmin();
    }

    match /assignments/{assignmentId} {
      // Regular users only see their own assigned accounts. Admins see all.
      allow list: if isSignedIn() && (isAdmin() || resource.data.ciOfficerId == request.auth.uid);
      allow get: if isSignedIn() && (isAdmin() || resource.data.ciOfficerId == request.auth.uid);
      allow create: if isAdmin() && isValidAssignment(request.resource.data);
      allow update: if isSignedIn() && isValidAssignment(request.resource.data) &&
                    (isAdmin() || request.auth.uid == resource.data.ciOfficerId);
      allow delete: if isAdmin();
    }
  }
}
