{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile information",
      "type": "object",
      "properties": {
        "fullName": { "type": "string" },
        "mobileNumber": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "user", "coordinator"] },
        "photoURL": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["fullName", "mobileNumber", "role"]
    },
    "AdminKey": {
      "title": "AdminKey",
      "description": "4-digit key for admin registration",
      "type": "object",
      "properties": {
        "key": { "type": "string" },
        "used": { "type": "boolean" },
        "createdBy": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["key", "used"]
    },
    "Assignment": {
      "title": "Assignment",
      "description": "Loan assignment and processing details",
      "type": "object",
      "properties": {
        "borrowerName": { "type": "string" },
        "mobileNumber": { "type": "string" },
        "accountType": { "type": "string", "enum": ["New", "Renewal", "Restructure", "Additional"] },
        "location": { "type": "string" },
        "tribe": { "type": "string", "enum": ["NCR", "Rizal", "Mindoro", "Cavite"] },
        "businessPin": { "type": "string" },
        "addressPin": { "type": "string" },
        "requestedAmount": { "type": "number" },
        "term": { "type": "string" },
        "intRate": { "type": "number" },
        "mop": { "type": "string", "enum": ["Weekly", "Semi-Monthly", "Monthly"] },
        "top": { "type": "string", "enum": ["Collection", "PDC"] },
        "ciOfficerId": { "type": "string" },
        "status": { "type": "string", "enum": ["Assigned", "Start to Perform Assignment", "Reviewing", "Field CIBI", "Cashflowing", "Report Submitted", "Completed", "Approved", "Denied"] },
        "timeline": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "step": { "type": "string" },
              "timestamp": { "type": "string", "format": "date-time" }
            }
          }
        },
        "approvedAmount": { "type": "number" },
        "approvedTerm": { "type": "string" },
        "approvedIntRate": { "type": "number" },
        "approvedMop": { "type": "string" },
        "approvedTop": { "type": "string" },
        "crecomComments": { "type": "string" },
        "netIncome": { "type": "number" },
        "ndiPercentage": { "type": "number" },
        "ndiValue": { "type": "number" },
        "validationResults": { "type": "object" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["borrowerName", "mobileNumber", "ciOfficerId", "status"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "Collection of user profiles"
    },
    "/adminKeys/{keyId}": {
      "schema": "AdminKey",
      "description": "Collection of admin registration keys"
    },
    "/assignments/{assignmentId}": {
      "schema": "Assignment",
      "description": "Collection of loan assignments"
    }
  }
}
