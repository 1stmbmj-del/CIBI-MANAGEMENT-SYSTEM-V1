{
  "entities": {
    "User": {
      "title": "User",
      "description": "Application user profile",
      "type": "object",
      "properties": {
        "fullName": { "type": "string" },
        "mobileNumber": { "type": "string" },
        "email": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "user"] },
        "photoURL": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["fullName", "mobileNumber", "email", "role", "createdAt"]
    },
    "AdminKey": {
      "title": "AdminKey",
      "description": "Keys used to register as admin",
      "type": "object",
      "properties": {
        "key": { "type": "string" },
        "used": { "type": "boolean" },
        "createdBy": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["key", "used", "createdAt"]
    },
    "Assignment": {
      "title": "Assignment",
      "description": "Loan assignment details",
      "type": "object",
      "properties": {
        "borrowerName": { "type": "string" },
        "mobileNumber": { "type": "string" },
        "accountType": { "type": "string" },
        "location": { "type": "string" },
        "tribe": { "type": "string" },
        "businessPin": { "type": "string" },
        "addressPin": { "type": "string" },
        "requestedAmount": { "type": "number" },
        "term": { "type": "string" },
        "intRate": { "type": "number" },
        "mop": { "type": "string" },
        "top": { "type": "string" },
        "ciOfficerId": { "type": "string" },
        "ciOfficerName": { "type": "string" },
        "status": { "type": "string" },
        "timeline": { "type": "array", "items": { "type": "object" } },
        "approvedAmount": { "type": "number" },
        "approvedTerm": { "type": "string" },
        "approvedIntRate": { "type": "number" },
        "approvedMop": { "type": "string" },
        "approvedTop": { "type": "string" },
        "crecomComments": { "type": "string" },
        "netIncome": { "type": "number" },
        "ndiPercentage": { "type": "number" },
        "ndiValue": { "type": "number" },
        "validationResults": { "type": "object" },
        "creditScore": {
          "type": "object",
          "properties": {
            "neighbor1": { "type": "string" },
            "neighbor2": { "type": "string" },
            "barangayVerification": { "type": "string" },
            "loanHistory": { "type": "string" },
            "goodCreditBackground": { "type": "string" },
            "cooperationOfApplicant": { "type": "string" },
            "totalAssetLiabilities": { "type": "string" },
            "houseOwnership": { "type": "string" },
            "childrenSchooling": { "type": "string" },
            "residingDuration": { "type": "string" },
            "houseMaterials": { "type": "string" },
            "businessLocation": { "type": "string" },
            "floodProne": { "type": "string" },
            "footTraffic": { "type": "string" },
            "businessSpace": { "type": "string" },
            "permitType": { "type": "string" },
            "businessDuration": { "type": "string" },
            "inventoryVsSales": { "type": "string" },
            "loanVsCashflow": { "type": "string" },
            "otherIncome": { "type": "string" },
            "businessKnowledge": { "type": "string" },
            "watchBusiness": { "type": "string" },
            "bankAccount": { "type": "string" },
            "cicCmapFindings": { "type": "string" },
            "medicalCondition": { "type": "string" },
            "civilStatus": { "type": "string" },
            "ageGroup": { "type": "string" },
            "educationalAttainment": { "type": "string" },
            "loanType": { "type": "string" },
            "sectionGrades": { "type": "object" },
            "totalGrade": { "type": "number" },
            "riskScore": { "type": "number" },
            "recommendation": { "type": "string", "enum": ["Approved", "Declined", "Conditional"] },
            "ciRemarks": { "type": "string" }
          }
        },
        "cashflowReport": {
          "type": "object",
          "properties": {
            "liabilities": { "type": "array" },
            "businessIncome": { "type": "object" },
            "householdExpenses": { "type": "object" },
            "analysis": { "type": "object" },
            "ciRecommendation": { "type": "object" },
            "operationRecommendation": { "type": "object" }
          }
        },
        "deniedComments": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["borrowerName", "mobileNumber", "accountType", "location", "tribe", "requestedAmount", "term", "intRate", "mop", "top", "ciOfficerId", "ciOfficerName", "status", "timeline", "createdAt"]
    },
    "Notification": {
      "title": "Notification",
      "description": "Real-time alerts for CI Officers",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "title": { "type": "string" },
        "message": { "type": "string" },
        "type": { "type": "string", "enum": ["info", "assignment", "status_change"] },
        "assignmentId": { "type": "string" },
        "read": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "title", "message", "type", "read", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles"
    },
    "/admin_keys/{keyId}": {
      "schema": "AdminKey",
      "description": "Registration keys"
    },
    "/assignments/{assignmentId}": {
      "schema": "Assignment",
      "description": "Loan assignments"
    },
    "/notifications/{notificationId}": {
      "schema": "Notification",
      "description": "User notifications"
    }
  }
}
